# HearthNet LLM Configuration
# Copy to .env and fill in your API key

# LLM provider: "anthropic" or "openai"
HEARTHNET_LLM_PROVIDER=anthropic

# API keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model override (optional)
# Anthropic default: claude-sonnet-4-20250514
# OpenAI default: gpt-4o
HEARTHNET_LLM_MODEL=

# Set to "true" to use deterministic mock responses instead of real LLM calls
# Mock mode reproduces the exact same protocol messages as the original demo scripts
HEARTHNET_MOCK_LLM=true

# HearthNet root secret for lease signing (REQUIRED)
HEARTHNET_ROOT_SECRET=

# MQTT broker configuration
MQTT_HOST=100.96.102.7
MQTT_PORT=1883
MQTT_USER=rupert
MQTT_PASS=agentcomms2026

# Ground truth repository path (optional, defaults to ./groundplane-state)
HEARTHNET_REPO=
